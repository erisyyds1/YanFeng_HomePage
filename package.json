{
  "name": "yanfeng-homepage",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:api": "cd backend && go run ./cmd/server",
    "build:frontend": "cd frontend && npm run build",
    "test:backend": "cd backend && go test ./...",
    "test:wechat-archive": "node scripts/test-wechat-archive-pagination.mjs",
    "test:we-mp-rss-config": "scripts/test-configure-we-mp-rss-env.sh",
    "configure:we-mp-rss": "scripts/configure-we-mp-rss-env.sh --yes",
    "deploy": "scripts/deploy.sh",
    "rollback": "scripts/rollback.sh",
    "backup:db": "scripts/backup-db.sh",
    "install:db-backup-cron": "scripts/install-db-backup-cron.sh",
    "build:we-mp-rss": "scripts/configure-we-mp-rss-env.sh --yes && docker compose build we-mp-rss",
    "compose:up": "docker compose up -d --build",
    "compose:down": "docker compose down"
  }
}
