DIFY_API_KEY=
DIFY_API_URL=https://api.dify.ai/v1

# Admin and JWT.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
JWT_TTL=6h

# Docker Compose.
HTTP_PORT=80
HTTPS_PORT=443
TLS_DOMAIN=yanfeng.club
LETSENCRYPT_DIR=./deploy/certs/letsencrypt
CERTBOT_WEBROOT=./deploy/certs/www
CLOUDFLARE_TUNNEL_TOKEN=
MYSQL_DATABASE=yanfeng_homepage
MYSQL_USER=yanfeng
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# we-mp-rss is built from third_party/we-mp-rss instead of pulling an upstream image.
# Run scripts/configure-we-mp-rss-env.sh to choose a local image tag for the host arch.
WE_MP_RSS_RUNTIME_ARCH=auto
WE_MP_RSS_LOCAL_IMAGE=yanfeng-homepage/we-mp-rss:local
WE_MP_RSS_BROWSER_TYPE=chromium
WE_MP_RSS_HEADLESS=true
WE_MP_RSS_AUTH_WEB=False
WE_MP_RSS_PAGE_SIZE=100
WE_MP_RSS_BIND=127.0.0.1
WE_MP_RSS_PORT=8001
WE_MP_RSS_SHM_SIZE=1gb

# Optional low-resource overrides for docker-compose.2c2g.yml.
WECHAT_RSS_LOW_MEM_MAX_ARTICLES=2000
WE_MP_RSS_LOW_MEM_PAGE_SIZE=50
WE_MP_RSS_LOW_MEM_SHM_SIZE=512m

# WeChat RSS sync. Full URLs and paths are both supported.
# In Docker, prefer paths copied from we-mp-rss UI, e.g. /rss/xxx.xml.
WECHAT_RSS_BASE_URL=http://we-mp-rss:8001
WECHAT_RSS_FEED_URLS=
WECHAT_RSS_MAX_ARTICLES=2000
WECHAT_RSS_DISPLAY_NAME_MAP=番剧鉴赏组=涧桐现视研

# Go API database. For production, keep DB_DRIVER=mysql and point DB_DSN to MySQL 8.
DB_DRIVER=mysql
DB_DSN=

# Go API local file storage. MinIO is reserved for a later migration step.
PUBLIC_DIR=../public
SEED_PATH=../db.json

# Optional for local development. When omitted, frontend calls same-origin /api.
VITE_API_URL=http://localhost:3001
